# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared LLM config
# Examples:
# Anthropic: https://api.anthropic.com
# DashScope (Alibaba OpenAI-compatible): https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.anthropic.com

# Optional: override the auto-selected model
# LLM_MODEL=claude-sonnet-4-5-20250929

# Vercel Cron Security
CRON_SECRET=your-random-secret-string

# Optional: Twitter/X API (for personal accounts monitoring)
# TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Optional: GitHub Token (higher rate limits for GitHub Trending)
# GITHUB_TOKEN=your-github-token
